# === PingCode API ===
PINGCODE_BASE_URL=https://open.pingcode.com

# 认证方式（二选一，推荐 Client Credentials）
# 方式一：Client Credentials（推荐，自动刷新）
PINGCODE_CLIENT_ID=your_client_id_here
PINGCODE_CLIENT_SECRET=your_client_secret_here

# 方式二：静态 Token（需手动更新）
# PINGCODE_TOKEN=your_bearer_token_here

# Token 模式
TOKEN_MODE=enterprise          # enterprise | user

# === Server ===
TRANSPORT_MODE=stdio           # stdio | http
HTTP_PORT=3000                 # HTTP 模式端口
HTTP_HOST=127.0.0.1            # HTTP 绑定地址（0.0.0.0 暴露到网络）

# === Auth (HTTP 模式) ===
MCP_API_KEY=your_secret_key    # API Key（HTTP 模式必填，否则启动失败）
MCP_API_KEYS=                  # 多 Key 支持：key1:id1,key2:id2（零停机轮换）
TRUST_PROXY=false              # 是否信任反向代理头（X-Forwarded-For, X-Real-IP）
ALLOWED_ORIGINS=               # 允许的 Origin（逗号分隔，防 DNS rebinding）

# === Session (HTTP 模式) ===
HTTP_MAX_SESSIONS=100          # 最大并发 Session 数
HTTP_SESSION_TTL_MS=1800000    # Session 空闲过期时间（ms，默认 30 分钟）

# === Cache ===
CACHE_TTL_USERS=3600           # 用户缓存 TTL（秒），默认 1 小时
CACHE_TTL_WORK_ITEMS=21600     # 工作项缓存 TTL（秒），默认 6 小时

# === Rate Limit ===
RATE_LIMIT_PER_MIN=200         # PingCode API 限制

# === Pagination ===
MAX_PAGES=200                  # 最大分页数（防止异常分页）
PAGE_SIZE=100                  # 每页记录数
MAX_RECORDS=50000              # 最大记录数
MAX_FETCH_DURATION_MS=180000   # 数据获取软超时（ms，默认 3 分钟）

# === Request ===
REQUEST_TIMEOUT=15000          # API 请求超时（ms）
TOOL_CALL_TIMEOUT_MS=300000    # 单次工具调用超时（ms，默认 5 分钟）

# === Timezone ===
TIMEZONE=Asia/Shanghai         # 企业默认时区

# === Name Matching ===
NAME_MATCH_STRATEGY=best       # best | strict | prompt

# === Logging ===
LOG_LEVEL=info                 # debug | info | warn | error

# === Data Quality ===
TRUNCATION_ALERT_THRESHOLD=0.3 # 截断率警告阈值（0-1）
